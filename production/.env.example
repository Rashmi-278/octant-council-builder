# OptInPG Production Environment Variables
# Copy to .env and fill in your values

# Backend (all 3 services)
COUNCIL_OUT_DIR=council-out
CORS_ORIGINS=*

# Turso Database (free tier: 9GB, 25M reads/month)
# Get credentials: turso db create optinpg && turso db tokens create optinpg
TURSO_URL=libsql://your-db-name.turso.io
TURSO_TOKEN=your-auth-token
# Fallback: if TURSO_URL is not set, uses local SQLite at DATABASE_PATH
DATABASE_PATH=evaluations.db

# Auto-publish evaluations to hosted dashboard
# Set in your Claude Code environment or .env
PUBLISH_OSTROM=true
PUBLISH_URL=https://your-evaluator.railway.app

# Public URL for generating dashboard links
PUBLIC_URL=https://your-frontend.netlify.app

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000

# EAS Attestation (used by dashboard, NOT by agents)
# NEVER put private keys in agent code — only in the dashboard env
# EAS_RPC_URL=https://mainnet.base.org
# EAS_SCHEMA_UID=0x...
